#!/usr/bin/env bash
# ==============================================================================
# AEGIS OS CLI - UNIFIED CONTROL INTERFACE (SRE GRADE)
# ==============================================================================

set -euo pipefail

INSTALL_DIR="/opt/aegis"
SERVICE_NAME="aegis"
DOCKER_SERVICE="ank-server"
BIN_PATH="/usr/local/bin/ank-server"
UI_PATH="/usr/share/aegis/ui"
GITHUB_ORG="Gustavo324234"
GITHUB_REPO="Aegis-Core"

CYAN='\033[0;36m'
GREEN='\033[0;32m'
RED='\033[0;31m'
YELLOW='\033[1;33m'
NC='\033[0m'

detect_mode() {
    if [[ -f "/etc/aegis/mode" ]]; then
        cat "/etc/aegis/mode"
    elif [[ -f "/etc/systemd/system/${SERVICE_NAME}.service" ]]; then
        echo "native"
    else
        echo "native"
    fi
}

detect_arch() {
    case "$(uname -m)" in
        x86_64)  echo "x86_64" ;;
        aarch64) echo "arm64" ;;
        *)       echo "x86_64" ;;
    esac
}

AEGIS_MODE=$(detect_mode)

cmd_start() {
    printf '%bStarting Aegis OS (%s)...%b\n' "$CYAN" "$AEGIS_MODE" "$NC"
    if [[ "$AEGIS_MODE" == "docker" ]]; then
        (cd "$INSTALL_DIR" || exit; docker compose up -d)
    else
        sudo systemctl start "$SERVICE_NAME"
    fi
}

cmd_stop() {
    printf '%bStopping Aegis OS (%s)...%b\n' "$CYAN" "$AEGIS_MODE" "$NC"
    if [[ "$AEGIS_MODE" == "docker" ]]; then
        (cd "$INSTALL_DIR" || exit; docker compose down)
    else
        sudo systemctl stop "$SERVICE_NAME"
    fi
}

cmd_status() {
    printf '%b--- Aegis OS Status (%s) ---%b\n' "$CYAN" "$AEGIS_MODE" "$NC"
    if [[ "$AEGIS_MODE" == "docker" ]]; then
        (cd "$INSTALL_DIR" || exit; docker compose ps) || echo "Docker not running."
    else
        sudo systemctl status "$SERVICE_NAME" --no-pager || true
    fi
    printf '\n%s--- API Health Check ---%s\n' "$CYAN" "$NC"

    local PROTOCOL="http"
    local CURL_FLAGS=("-s" "-f" "--connect-timeout" "2")

    if curl "${CURL_FLAGS[@]}" "${PROTOCOL}://localhost:8000/health" > /dev/null 2>&1; then
        printf '%sAPI is UP (%s://localhost:8000)%s\n' "$GREEN" "$PROTOCOL" "$NC"
        
        local conn_info
        conn_info=$(curl -s "${PROTOCOL}://localhost:8000/api/system/connection-info" || true)
        if [[ -n "$conn_info" ]]; then
            local tunnel_url
            tunnel_url=$(echo "$conn_info" | grep -oP '(?<="tunnel_url":")[^"]+')
            if [[ -n "$tunnel_url" ]]; then
                printf '%sRemote Access (HTTPS): %s%s%s\n' "$GREEN" "$CYAN" "$tunnel_url" "$NC"
            else
                printf '%sRemote Access: %sConnecting...%s\n' "$YELLOW" "$CYAN" "$NC"
            fi
        fi
    else
        printf '%sAPI is DOWN or unreachable%s\n' "$RED" "$NC"
    fi
}

cmd_logs() {
    local n
    n="${1:-100}"
    if [[ "$AEGIS_MODE" == "docker" ]]; then
        (cd "$INSTALL_DIR" || exit; docker compose logs -f --tail "$n" "$DOCKER_SERVICE")
    else
        sudo journalctl -u "$SERVICE_NAME" -f -n "$n"
    fi
}

# CORE-FIX: `aegis logs` dumps EVERYTHING the kernel emits, which on a real
# smoke test means dozens of lines of tokio channel structures, repeated
# "Secure Enclave initialized", and multi-page Gemini RESOURCE_EXHAUSTED
# JSON bodies per failure. `aegis trace` keeps only the events you need to
# follow a model request end-to-end:
#
#   T+0.0s [ROUTE]    proc_360b187c → gemini-2.5-pro (gemini) Chat fb=deepseek-v3.2,deepseek-v4-flash
#   T+0.4s [429]      gemini-2.5-pro key=640c3b9b cooldown=60s
#   T+1.6s [ROTATE]   alternate key 7937be8d also failed (429)
#   T+3.5s [FALLBACK] deepseek-v3.2 failed (401)
#   T+3.7s [EMPTY]    model returned 0 content tokens (6.5s)
#   T+3.7s [DONE]     proc_360b187c output="" (0 chars)
#
# Flags:
#   -n N             only the last N journalctl lines (default 500)
#   --pid PID        only events for this proc_xxx id
#   --since "5m ago" passthrough to journalctl --since
#   --no-follow      don't tail; print and exit
cmd_trace() {
    local n=500
    local pid_filter=""
    local since=""
    local follow=true
    while [[ $# -gt 0 ]]; do
        case "$1" in
            -n)         n="$2"; shift 2 ;;
            --pid)      pid_filter="$2"; shift 2 ;;
            --since)    since="$2"; shift 2 ;;
            --no-follow) follow=false; shift ;;
            *) shift ;;
        esac
    done

    local follow_flag="-f"
    [[ "$follow" == "false" ]] && follow_flag=""
    local since_flag=""
    [[ -n "$since" ]] && since_flag="--since \"$since\""

    local cmd
    if [[ "$AEGIS_MODE" == "docker" ]]; then
        cmd="cd \"$INSTALL_DIR\" && docker compose logs $follow_flag --tail $n $DOCKER_SERVICE"
    else
        cmd="sudo journalctl -u $SERVICE_NAME $follow_flag -n $n --no-pager $since_flag"
    fi

    # The filter uses awk for line-oriented state (so it can skip the multi-line
    # JSON bodies between an error header and its closing `]`). Stays POSIX so
    # both mawk (Debian default) and gawk work — no 3-arg match(), no gensub().
    eval "$cmd" | awk -v pid_filter="$pid_filter" '
        BEGIN {
            DIM  = "\033[2m"; BOLD = "\033[1m"
            RED  = "\033[31m"; YEL = "\033[33m"; GRN = "\033[32m"
            CYA  = "\033[36m"; MAG = "\033[35m"; RST = "\033[0m"
            in_json = 0
            t0 = 0
        }

        # Extract `key=value` (value is a non-space, non-quote run) using 2-arg
        # match() so we work on POSIX awk too. Returns "" if missing.
        function field(line, key,    pat, v) {
            pat = key "=[^ \t\"]+"
            if (!match(line, pat)) return ""
            v = substr(line, RSTART, RLENGTH)
            sub(key "=", "", v)
            return v
        }

        # Extract a bracketed value: fallback_chain=[a, b, c] → "[a, b, c]"
        function bracketed(line, key,    pat, v) {
            pat = key "=\\[[^]]*\\]"
            if (!match(line, pat)) return ""
            v = substr(line, RSTART, RLENGTH)
            sub(key "=", "", v)
            return v
        }

        # Relative timestamp anchored at first matched event.
        function rel_ts(line,    secs, parts, n, h, m, s, fr) {
            if (!match(line, /T[0-9][0-9]:[0-9][0-9]:[0-9][0-9]\.[0-9]+Z/)) return "T+ ?  "
            s = substr(line, RSTART + 1, RLENGTH - 2)
            n = split(s, parts, ":")
            h = parts[1] + 0; m = parts[2] + 0; fr = parts[3] + 0
            secs = h * 3600 + m * 60 + fr
            if (t0 == 0) t0 = secs
            return sprintf("T+%5.1fs", secs - t0)
        }

        # Find a proc_xxx token anywhere on the line.
        function find_pid(line,    p) {
            if (!match(line, /proc_[a-f0-9]+/)) return ""
            return substr(line, RSTART, RLENGTH)
        }

        function pid_ok(line) {
            if (pid_filter == "") return 1
            p = find_pid(line)
            if (p == "") return 1   # no pid on this line — let it through
            return p == pid_filter
        }

        # Suppress the multi-line JSON bodies that follow a 429 / quota error.
        # Header looks like  ...error=Hardware Failure: API Error 429... : [{
        # and runs until a line that ends with `]`.
        in_json == 1 {
            if ($0 ~ /\][[:space:]]*$/) in_json = 0
            next
        }
        /error=Hardware Failure: API Error [0-9]+/ {
            if ($0 ~ /\[\{[[:space:]]*$/) in_json = 1
        }

        /CognitiveRouter: routing decision/ {
            if (!pid_ok($0)) next
            cat = field($0, "catalog_id"); prov = field($0, "provider")
            task = field($0, "task_type"); tenant = field($0, "tenant")
            fb = bracketed($0, "fallback_chain")
            printf "%s %s[ROUTE]%s    %s → %s%s%s (%s) %s%s%s fb=%s\n",
                rel_ts($0), CYA, RST, tenant, BOLD, cat, RST, prov, DIM, task, RST, fb
            next
        }

        /key marcada como rate-limited/ {
            if (!pid_ok($0)) next
            printf "%s %s[429]%s      %s cooldown=%ss\n",
                rel_ts($0), YEL, RST, field($0, "model"), field($0, "cooldown_secs")
            next
        }

        /Cloud API returned error status/ {
            if (!pid_ok($0)) next
            st = field($0, "status"); body = field($0, "body")
            printf "%s %s[ERR]%s      status=%s body=%s\n",
                rel_ts($0), RED, RST, st, body
            next
        }

        /trying key rotation then fallback chain/ {
            if (!pid_ok($0)) next
            printf "%s %s[ROTATE]%s   primary=%s failed — trying alt keys + fallback\n",
                rel_ts($0), MAG, RST, field($0, "primary")
            next
        }
        /alternate key also failed/ {
            if (!pid_ok($0)) next
            kid = field($0, "key_id")
            printf "%s %s[ROTATE]%s   alternate key %s (attempt %s) failed\n",
                rel_ts($0), MAG, RST, substr(kid, 1, 8), field($0, "attempt")
            next
        }
        /fallback model also failed/ {
            if (!pid_ok($0)) next
            printf "%s %s[FALLBACK]%s %s also failed\n",
                rel_ts($0), MAG, RST, field($0, "fallback")
            next
        }

        /CognitiveRouter: routing to model/ {
            if (!pid_ok($0)) next
            printf "%s %s[CALL]%s     %s (%s)\n",
                rel_ts($0), CYA, RST, field($0, "model"), field($0, "provider")
            next
        }

        /model returned 0 content tokens/ {
            if (!pid_ok($0)) next
            printf "%s %s[EMPTY]%s    upstream returned 0 tokens (%sms)\n",
                rel_ts($0), RED, RST, field($0, "duration_ms")
            next
        }

        /ReAct: tool ejecutado/ {
            if (!pid_ok($0)) next
            printf "%s %s[TOOL]%s     %s\n",
                rel_ts($0), GRN, RST, field($0, "tool")
            next
        }

        /ProcessCompleted \{ pid:/ {
            if (!pid_ok($0)) next
            pid = find_pid($0)
            # output:"..." can be empty or contain escaped \n.
            out = ""; outlen = 0
            if (match($0, /output: "[^"]*"/)) {
                out = substr($0, RSTART, RLENGTH)
                sub(/output: "/, "", out); sub(/"$/, "", out)
                outlen = length(out)
                if (outlen > 60) out = substr(out, 1, 60) "..."
                gsub(/\\n/, " ", out)
            }
            if (outlen == 0)
                printf "%s %s[DONE]%s     %s output=%s(empty)%s\n",
                    rel_ts($0), RED, RST, pid, RED, RST
            else
                printf "%s %s[DONE]%s     %s output=\"%s\" (%d chars)\n",
                    rel_ts($0), GRN, RST, pid, out, outlen
            next
        }

        /ProjectSupervisor created/ {
            ag = field($0, "agent")
            printf "%s %s[AGENT+]%s   %s spawned for %s\n",
                rel_ts($0), CYA, RST, substr(ag, 1, 8), field($0, "project")
            next
        }
        /LLM execution failed/ {
            printf "%s %s[AGENT!]%s   sub-agent LLM call failed\n",
                rel_ts($0), RED, RST
            next
        }
    '
}

cmd_diag() {
    printf '%s================================================================%s\n' "$CYAN" "$NC"
    printf '%s   AEGIS OS - SRE DIAGNOSTIC REPORT%s\n' "$CYAN" "$NC"
    printf '%s================================================================%s\n\n' "$CYAN" "$NC"
    printf '%s[1] SYSTEM RESOURCE USAGE%s\n' "$YELLOW" "$NC"
    ps -u aegis -o %cpu,%mem,cmd 2>/dev/null || echo "Aegis process not found."
    printf '\n%s[2] NETWORK & PORTS%s\n' "$YELLOW" "$NC"
    ss -tulpn | grep -E "8000|50051" || echo "Aegis ports not listening."
    printf '\n%s[3] RECENT ERROR LOGS%s\n' "$YELLOW" "$NC"
    if [[ "$AEGIS_MODE" == "docker" ]]; then
        (cd "$INSTALL_DIR" || exit; docker compose logs --tail 20 "$DOCKER_SERVICE" | grep -i "error") || echo "No recent errors found."
    else
        sudo journalctl -u "$SERVICE_NAME" -n 50 --no-pager | grep -i "error" | tail -n 10 || echo "No recent errors found."
    fi
    printf '\n%s[4] CONFIGURATION%s\n' "$YELLOW" "$NC"
    ls -l /etc/aegis/aegis.env 2>/dev/null || echo "Config file missing."
    printf '\n%s================================================================%s\n' "$CYAN" "$NC"
}

cmd_version() {
    if [[ -f "$BIN_PATH" ]]; then
        "$BIN_PATH" --version
    else
        printf '%b%s%b\n' "$RED" "Aegis binario no encontrado en $BIN_PATH" "$NC"
    fi
}

cmd_update() {
    # Default: nightly (único canal activo mientras el proyecto está en desarrollo)
    local CHANNEL="nightly"
    local TAG="nightly"

    while [[ $# -gt 0 ]]; do
        case "$1" in
            --beta|--nightly) CHANNEL="nightly"; TAG="nightly"; shift ;;
            --stable)         CHANNEL="stable";  TAG="latest";  shift ;;
            *) shift ;;
        esac
    done

    local ARCH
    ARCH=$(detect_arch)
    local RELEASE_URL="https://github.com/${GITHUB_ORG}/${GITHUB_REPO}/releases/download/${TAG}"
    local RAW_URL="https://raw.githubusercontent.com/${GITHUB_ORG}/${GITHUB_REPO}/main/installer"

    printf '%b%s%b\n' "$CYAN" "--- Aegis OS Upgrade Tool ---" "$NC"
    printf 'Canal: %b%s%b (Tag: %s)\n' "$YELLOW" "$CHANNEL" "$NC" "$TAG"

    # CORE-FIX: refresh this very script + the systemd unit BEFORE doing the
    # rest of the update. Bash loads the script into memory at invocation, so
    # rewriting the file on disk is safe — the running update continues with
    # the old logic and the new version takes effect on the NEXT `aegis update`.
    # This is what makes future installer fixes (env-var backfills, new flags)
    # actually reach already-deployed users. Without it, any improvement to the
    # update flow is invisible until the operator manually re-runs install.sh.
    local self_path="${BASH_SOURCE[0]}"
    local self_tmp="/tmp/aegis-cli-update.$$"
    if curl -sL --fail "${RAW_URL}/aegis" -o "$self_tmp" 2>/dev/null; then
        # Sanity check — refuse to install a CLI script that isn't a bash script
        # (catches GitHub returning an HTML 404 page or rate-limit JSON).
        if head -1 "$self_tmp" | grep -q '^#!.*bash'; then
            if ! cmp -s "$self_tmp" "$self_path"; then
                printf '  → Self-updating CLI (%s)\n' "$self_path"
                sudo cp "$self_tmp" "$self_path"
                sudo chmod +x "$self_path"
                printf '%b  → CLI updated. The change takes effect on the next aegis update run.%b\n' "$GREEN" "$NC"
            fi
        else
            printf '%b  → Skipped self-update: downloaded file is not a bash script%b\n' "$YELLOW" "$NC"
        fi
        rm -f "$self_tmp"
    fi

    local unit_path="/etc/systemd/system/${SERVICE_NAME}.service"
    local unit_tmp="/tmp/aegis-unit-update.$$"
    if [[ -f "$unit_path" ]] && curl -sL --fail "${RAW_URL}/aegis.service" -o "$unit_tmp" 2>/dev/null; then
        if head -1 "$unit_tmp" | grep -q '^\[Unit\]'; then
            if ! cmp -s "$unit_tmp" "$unit_path"; then
                printf '  → Updating systemd unit (%s)\n' "$unit_path"
                sudo cp "$unit_tmp" "$unit_path"
                sudo systemctl daemon-reload
                printf '%b  → Unit updated + daemon-reload done.%b\n' "$GREEN" "$NC"
            fi
        fi
        rm -f "$unit_tmp"
    fi

    printf "Versión actual: "
    cmd_version || true

    local remote_info
    remote_info=$(curl -s "https://api.github.com/repos/${GITHUB_ORG}/${GITHUB_REPO}/releases/tags/${TAG}")
    local remote_date
    remote_date=$(echo "$remote_info" | grep '"published_at"' | head -1 | grep -oP '"\K[^"]+(?=")' || echo "unknown")

    printf 'Última disponible: %b%s%b\n\n' "$GREEN" "$remote_date" "$NC"

    printf "  → Deteniendo servicio...\n"
    sudo systemctl stop "$SERVICE_NAME" 2>/dev/null || true

    printf "  → Descargando binario (%s)...\n" "$ARCH"
    if ! curl -L --fail --progress-bar \
        "${RELEASE_URL}/ank-server-linux-${ARCH}.tar.gz" \
        -o /tmp/ank-update.tar.gz; then
        printf '%bError: No se pudo descargar el binario (canal: %s, tag: %s).%b\n' "$RED" "$CHANNEL" "$TAG" "$NC"
        printf '%bSugerencia: intentá con '"'"'sudo aegis update'"'"' (usa nightly por defecto).%b\n' "$YELLOW" "$NC"
        sudo systemctl start "$SERVICE_NAME"
        exit 1
    fi

    tar -xzf /tmp/ank-update.tar.gz -C /tmp/
    sudo mv "/tmp/ank-server-linux-${ARCH}" "$BIN_PATH"
    sudo chmod +x "$BIN_PATH"
    rm -f /tmp/ank-update.tar.gz

    printf "  → Descargando UI...\n"
    if curl -L --fail --progress-bar \
        "${RELEASE_URL}/ui-dist.tar.gz" \
        -o /tmp/ui-update.tar.gz 2>/dev/null; then
        sudo mkdir -p "$UI_PATH"
        sudo tar -xzf /tmp/ui-update.tar.gz -C "$UI_PATH"
        sudo chown -R aegis:aegis "$UI_PATH" 2>/dev/null || true
        rm -f /tmp/ui-update.tar.gz
    else
        printf '%b%s%b\n' "$YELLOW" "  Aviso: UI no disponible en este release, manteniendo actual." "$NC"
    fi

    printf "  → Actualizando archivos de instrucciones de agentes...\n"
    if curl -L --fail --progress-bar \
        "${RELEASE_URL}/agents-config.tar.gz" \
        -o /tmp/agents-update.tar.gz 2>/dev/null; then
        sudo mkdir -p /etc/aegis/agents
        sudo tar -xzf /tmp/agents-update.tar.gz -C /etc/aegis/agents
        rm -f /tmp/agents-update.tar.gz
        # Ensure AEGIS_AGENTS_CONFIG_DIR is in the env file
        if [[ -f /etc/aegis/aegis.env ]]; then
            grep -q "AEGIS_AGENTS_CONFIG_DIR" /etc/aegis/aegis.env \
                || echo "AEGIS_AGENTS_CONFIG_DIR=/etc/aegis/agents" | sudo tee -a /etc/aegis/aegis.env > /dev/null
        fi
        printf '%b  → Instruction files updated → /etc/aegis/agents%b\n' "$GREEN" "$NC"
    else
        printf '%b  → Aviso: agents-config no disponible en este release — se usan los fallbacks del binario%b\n' "$YELLOW" "$NC"
    fi

    # CORE-FIX: release builds added by PR #277 refuse to start without
    # AEGIS_PLUGIN_ROOT_KEY. If the user is upgrading from a version that
    # didn't require it, backfill AEGIS_ALLOW_INSECURE_PLUGINS=1 so the
    # service still boots after the update. The previous behaviour (silent
    # fall-through to a zero-byte signer key) was no more secure than this
    # explicit flag, so we're not regressing security — just making it
    # visible. To harden later: generate an ed25519 keypair, set
    # AEGIS_PLUGIN_ROOT_KEY=<hex>, and remove the insecure flag.
    if [[ -f /etc/aegis/aegis.env ]]; then
        if ! grep -qE "^(AEGIS_PLUGIN_ROOT_KEY|AEGIS_ALLOW_INSECURE_PLUGINS)=" /etc/aegis/aegis.env; then
            echo "AEGIS_ALLOW_INSECURE_PLUGINS=1" | sudo tee -a /etc/aegis/aegis.env > /dev/null
            printf '%b  → Backfilled AEGIS_ALLOW_INSECURE_PLUGINS=1 (required by release builds since PR #277)%b\n' "$YELLOW" "$NC"
        fi
    fi

    # CORE-147: Ensure cloudflared is installed
    if ! command -v cloudflared &>/dev/null; then
        printf "  → Instalando cloudflared...\n"
        local arch_str="amd64"
        [[ "$(uname -m)" == "aarch64" ]] && arch_str="arm64"
        local url="https://github.com/cloudflare/cloudflared/releases/latest/download/cloudflared-linux-${arch_str}"
        if sudo curl -L --fail --silent "$url" -o /usr/bin/cloudflared && sudo chmod 755 /usr/bin/cloudflared; then
            printf '%b  → cloudflared instalado en /usr/bin%b\n' "$GREEN" "$NC"
        elif sudo curl -L --fail --silent "$url" -o /usr/local/bin/cloudflared && sudo chmod 755 /usr/local/bin/cloudflared; then
            printf '%b  → cloudflared instalado en /usr/local/bin%b\n' "$GREEN" "$NC"
        else
            printf '%b  → cloudflared no disponible — acceso solo LAN%b\n' "$YELLOW" "$NC"
        fi
    fi

    printf "  \u2192 Iniciando servicio...\n"
    sudo systemctl start "$SERVICE_NAME"

    printf '\n%b%s%b\n' "$GREEN" "Actualización completada." "$NC"
    printf "Nueva versión: "
    cmd_version
}

cmd_token() {
    printf '%sRetrieving Setup Token...%s\n' "$CYAN" "$NC"
    local token=""
    if [[ "$AEGIS_MODE" == "docker" ]]; then
        token=$(cd "$INSTALL_DIR" || exit; docker compose logs "$DOCKER_SERVICE" 2>&1 | grep -oP 'setup_token=\K[a-f0-9]{32}' | tail -n 1 || true)
    else
        token=$(sudo journalctl -u "$SERVICE_NAME" -n 2000 --no-pager | grep -oP 'setup_token=\K[a-f0-9]{32}' | tail -n 1 || true)
    fi

    if [[ -z "$token" ]]; then
        printf '%sNo setup token found. System may already be initialized.%s\n' "$YELLOW" "$NC"
    else
        local ip
        ip=$(hostname -I | awk '{print $1}' || echo "localhost")
        local PROTOCOL="http"
        printf '\n%bSetup URL: %s://%s:8000?setup_token=%s%b\n' "$GREEN" "$PROTOCOL" "$ip" "$token" "$NC"
    fi
}

cmd_uninstall() {
    sudo bash -c "$(curl -sSL https://raw.githubusercontent.com/Gustavo324234/Aegis-Core/main/installer/uninstall.sh)" -- "$@"
}

cmd_tunnel() {
    printf '%b--- Aegis OS Cloudflare Tunnel ---%b\n' "$CYAN" "$NC"
    if ! command -v cloudflared &>/dev/null; then
        printf '%bError: cloudflared no está instalado.%b\n' "$RED" "$NC"
        printf 'Ejecutá %bsudo aegis update%b para instalarlo.\n' "$YELLOW" "$NC"
        exit 1
    fi
    
    local protocol="http"
    local port=8000
    
    printf 'Iniciando túnel hacia %s://localhost:%s...\n' "$protocol" "$port"
    printf '%bPresioná Ctrl+C para detener el túnel.%b\n\n' "$YELLOW" "$NC"
    
    cloudflared tunnel --url "${protocol}://localhost:${port}"
}

case "${1:-help}" in
    start)     shift; cmd_start "$@" ;;
    stop)      shift; cmd_stop "$@" ;;
    restart)   shift; cmd_stop "$@"; cmd_start "$@" ;;
    status)    shift; cmd_status "$@" ;;
    diag)      shift; cmd_diag "$@" ;;
    logs)      shift; cmd_logs "$@" ;;
    trace)     shift; cmd_trace "$@" ;;
    update)    shift; cmd_update "$@" ;;
    tunnel)    shift; cmd_tunnel "$@" ;;
    version)   shift; cmd_version "$@" ;;
    token)     shift; cmd_token "$@" ;;
    uninstall) shift; cmd_uninstall "$@" ;;
    help|*)
        echo "Aegis OS Unified CLI"
        echo ""
        echo "Usage: aegis {command} [args]"
        echo ""
        echo "Commands:"
        echo "  start         Start Aegis service"
        echo "  stop          Stop Aegis service"
        echo "  restart       Restart Aegis service"
        echo "  status        Check status and health"
        echo "  diag          Run deep diagnostic report"
        echo "  version       Show installed core version"
        echo "  logs [N]      Follow logs (default 100)"
        echo "  trace [OPTS]  Follow filtered model-routing events only (no JSON walls)"
