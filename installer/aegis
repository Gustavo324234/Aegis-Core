#!/usr/bin/env bash
# ==============================================================================
# AEGIS OS CLI - Unified Control Interface
# ==============================================================================
# Description: Management toolkit for Aegis OS (Native/Docker)
# Ticket: CORE-043
# ==============================================================================

set -euo pipefail

# --- Configuration ---
INSTALL_DIR="/opt/aegis"
BIN_DIR="/usr/local/bin"
SERVICE_NAME="aegis"
DOCKER_SERVICE="ank-server"

# Colors
CYAN='\033[0;36m'
GREEN='\033[0;32m'
RED='\033[0;31m'
YELLOW='\033[1;33m'
NC='\033[0m'

# --- Detection Logic ---
detect_mode() {
    if [[ -f "/etc/aegis/mode" ]]; then
        cat "/etc/aegis/mode"
    elif [[ -f "/etc/systemd/system/${SERVICE_NAME}.service" ]]; then
        echo "native"
    elif [[ -f "${INSTALL_DIR}/docker-compose.yml" ]]; then
        echo "docker"
    else
        echo "${AEGIS_MODE:-native}"
    fi
}

AEGIS_MODE=$(detect_mode)

# --- Commands ---

cmd_start() {
    echo -e "${CYAN}Starting Aegis OS (${AEGIS_MODE})...${NC}"
    if [[ "$AEGIS_MODE" == "docker" ]]; then
        (cd "$INSTALL_DIR" && docker compose up -d)
    else
        systemctl start "$SERVICE_NAME"
    fi
}

cmd_stop() {
    echo -e "${CYAN}Stopping Aegis OS (${AEGIS_MODE})...${NC}"
    if [[ "$AEGIS_MODE" == "docker" ]]; then
        (cd "$INSTALL_DIR" && docker compose down)
    else
        systemctl stop "$SERVICE_NAME"
    fi
}

cmd_status() {
    echo -e "${CYAN}--- Aegis OS Status (${AEGIS_MODE}) ---${NC}"
    if [[ "$AEGIS_MODE" == "docker" ]]; then
        if command -v docker &> /dev/null; then
            (cd "$INSTALL_DIR" && docker compose ps)
        else
            echo -e "${RED}Error: docker not found.${NC}"
        fi
    else
        systemctl status "$SERVICE_NAME" --no-pager || true
    fi
    
    echo -e "\n${CYAN}--- API Health Check ---${NC}"
    if curl -s -f http://localhost:8000/health > /dev/null; then
        echo -e "${GREEN}API is UP (http://localhost:8000)${NC}"
    else
        echo -e "${RED}API is DOWN or unreachable${NC}"
    fi
}

cmd_logs() {
    local n="${1:-100}"
    # Ensure n is a number
    if ! [[ "$n" =~ ^[0-9]+$ ]]; then n=100; fi

    echo -e "${CYAN}Showing last $n logs (use Ctrl+C to stop)...${NC}"
    if [[ "$AEGIS_MODE" == "docker" ]]; then
        (cd "$INSTALL_DIR" && docker compose logs -f --tail "$n" "$DOCKER_SERVICE")
    else
        journalctl -u "$SERVICE_NAME" -f -n "$n"
    fi
}

cmd_update() {
    echo -e "${YELLOW}Updating Aegis OS (${AEGIS_MODE})...${NC}"
    if [[ "$AEGIS_MODE" == "docker" ]]; then
        (cd "$INSTALL_DIR" && docker compose pull && docker compose up -d)
    else
        # Native update logic
        local arch
        arch=$(uname -m)
        case "$arch" in
            x86_64)  ARCH="x86_64" ;;
            aarch64) ARCH="arm64" ;;
            *)       echo -e "${RED}Unsupported architecture: $arch${NC}"; exit 1 ;;
        esac
        
        local org="Gustavo324234"
        local repo="Aegis-Core"
        local url="https://github.com/${org}/${repo}/releases/latest/download/ank-server-linux-${ARCH}"
        
        echo -e "${CYAN}Downloading latest binary from: ${url}${NC}"
        # Use a temporary file to avoid partial writes to the running binary
        if curl -L --fail --progress-bar "$url" -o "${BIN_DIR}/ank-server.new"; then
            chmod +x "${BIN_DIR}/ank-server.new"
            mv "${BIN_DIR}/ank-server.new" "${BIN_DIR}/ank-server"
            echo -e "${GREEN}Binary updated successfully.${NC}"
            
            echo -e "${CYAN}Restarting service...${NC}"
            systemctl restart "$SERVICE_NAME"
        else
            echo -e "${RED}Failed to download update.${NC}"
            exit 1
        fi
    fi
    echo -e "${GREEN}Update process finished.${NC}"
}

cmd_token() {
    echo -e "${CYAN}Retrieving Setup Token...${NC}"
    local token=""
    if [[ "$AEGIS_MODE" == "docker" ]]; then
        token=$(cd "$INSTALL_DIR" && docker compose logs "$DOCKER_SERVICE" 2>&1 | grep "setup_token=" | tail -n 1 | sed 's/.*setup_token=\([^ ]*\).*/\1/' || echo "")
    else
        token=$(journalctl -u "$SERVICE_NAME" -n 2000 --no-pager | grep "setup_token=" | tail -n 1 | sed 's/.*setup_token=\([^ ]*\).*/\1/' || echo "")
    fi

    if [[ -z "$token" ]]; then
        echo -e "${YELLOW}No setup token found in recent logs.${NC}"
        echo -e "If the system is already initialized, token generation is disabled."
    else
        echo -e "\n${GREEN}################################################################${NC}"
        echo -e "${GREEN}#          AEGIS OS - SETUP TOKEN                              #${NC}"
        echo -e "${GREEN}################################################################${NC}"
        echo ""
        local ip
        ip=$(hostname -I 2>/dev/null | awk '{print $1}') || ip="localhost"
        echo -e "  URL: ${CYAN}http://$ip:8000?setup_token=$token${NC}"
        echo ""
        echo -e "${GREEN}################################################################${NC}"
    fi
}

cmd_uninstall() {
    echo -e "${CYAN}Downloading/Running uninstaller...${NC}"
    
    # Try to use the local one if available, otherwise fetch from main
    if [[ -f "$(dirname "$0")/uninstall.sh" ]]; then
        bash "$(dirname "$0")/uninstall.sh"
    elif [[ -f "${INSTALL_DIR}/uninstall.sh" ]]; then
        bash "${INSTALL_DIR}/uninstall.sh"
    else
        curl -sSL "https://raw.githubusercontent.com/Gustavo324234/Aegis-Core/main/installer/uninstall.sh" | sudo bash
    fi
}

# --- Execution ---

case "${1:-help}" in
    start)     cmd_start ;;
    stop)      cmd_stop ;;
    restart)   cmd_stop; cmd_start ;;
    status)    cmd_status ;;
    logs)      cmd_logs "${2:-}" ;;
    update)    cmd_update ;;
    token)     cmd_token ;;
    uninstall) cmd_uninstall ;;
    help|*)
        echo "Aegis OS Unified CLI"
        echo ""
        echo "Usage: aegis {start|stop|restart|status|logs|update|token|uninstall}"
        echo ""
        echo "Commands:"
        echo "  start       Start the service"
        echo "  stop        Stop the service"
        echo "  restart     Restart the service"
        echo "  status      Check system status and health"
        echo "  logs [N]    Show logs (default last 100 lines)"
        echo "  update      Update to latest version"
        echo "  token       Show active setup_token"
        echo "  uninstall   Completely remove Aegis OS from system"
        exit 1
        ;;
esac
