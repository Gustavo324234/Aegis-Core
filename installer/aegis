#!/usr/bin/env bash
# ==============================================================================
# AEGIS OS CLI - UNIFIED CONTROL INTERFACE (SRE GRADE)
# ==============================================================================
# Description: Professional management toolkit for Aegis OS
# Ticket: CORE-043, CORE-090
# ==============================================================================

set -euo pipefail

# --- Configuration ---
INSTALL_DIR="/opt/aegis"
SERVICE_NAME="aegis"
DOCKER_SERVICE="ank-server"

# Colors
CYAN='\033[0;36m'
GREEN='\033[0;32m'
RED='\033[0;31m'
YELLOW='\033[1;33m'
NC='\033[0m'

# --- Detection Logic ---
detect_mode() {
    if [[ -f "/etc/aegis/mode" ]]; then
        cat "/etc/aegis/mode"
    elif [[ -f "/etc/systemd/system/${SERVICE_NAME}.service" ]]; then
        echo "native"
    else
        echo "native"
    fi
}

AEGIS_MODE=$(detect_mode)

# --- Commands ---

cmd_start() {
    echo -e "${CYAN}Starting Aegis OS (${AEGIS_MODE})...${NC}"
    if [[ "$AEGIS_MODE" == "docker" ]]; then
        (cd "$INSTALL_DIR" && docker compose up -d)
    else
        systemctl start "$SERVICE_NAME"
    fi
}

cmd_stop() {
    echo -e "${CYAN}Stopping Aegis OS (${AEGIS_MODE})...${NC}"
    if [[ "$AEGIS_MODE" == "docker" ]]; then
        (cd "$INSTALL_DIR" && docker compose down)
    else
        systemctl stop "$SERVICE_NAME"
    fi
}

cmd_status() {
    echo -e "${CYAN}--- Aegis OS Status (${AEGIS_MODE}) ---${NC}"
    if [[ "$AEGIS_MODE" == "docker" ]]; then
        (cd "$INSTALL_DIR" && docker compose ps) || echo "Docker not running."
    else
        systemctl status "$SERVICE_NAME" --no-pager || true
    fi
    
    echo -e "\n${CYAN}--- API Health Check ---${NC}"
    if curl -s -f --connect-timeout 2 http://localhost:8000/health > /dev/null; then
        echo -e "${GREEN}API is UP (http://localhost:8000)${NC}"
    else
        echo -e "${RED}API is DOWN or unreachable${NC}"
    fi
}

cmd_logs() {
    local n="${1:-100}"
    if [[ "$AEGIS_MODE" == "docker" ]]; then
        (cd "$INSTALL_DIR" && docker compose logs -f --tail "$n" "$DOCKER_SERVICE")
    else
        journalctl -u "$SERVICE_NAME" -f -n "$n"
    fi
}

cmd_diag() {
    echo -e "${CYAN}================================================================${NC}"
    echo -e "${CYAN}   AEGIS OS - SRE DIAGNOSTIC REPORT                             ${NC}"
    echo -e "${CYAN}================================================================${NC}"
    echo ""
    echo -e "${YELLOW}[1] SYSTEM RESOURCE USAGE${NC}"
    ps -u aegis -o %cpu,%mem,cmd 2>/dev/null || echo "Aegis process not found."
    echo ""
    echo -e "${YELLOW}[2] NETWORK & PORTS${NC}"
    ss -tulpn | grep -E "8000|50051" || echo "Aegis ports not listening."
    echo ""
    echo -e "${YELLOW}[3] RECENT ERROR LOGS${NC}"
    if [[ "$AEGIS_MODE" == "docker" ]]; then
        (cd "$INSTALL_DIR" && docker compose logs --tail 20 "$DOCKER_SERVICE" | grep -i "error") || echo "No recent errors found."
    else
        journalctl -u "$SERVICE_NAME" -n 50 --no-pager | grep -i "error" | tail -n 10 || echo "No recent errors found."
    fi
    echo ""
    echo -e "${YELLOW}[4] CONFIGURATION${NC}"
    ls -l /etc/aegis/aegis.env 2>/dev/null || echo "Config file missing."
    echo ""
    echo -e "${CYAN}================================================================${NC}"
}

cmd_update() {
    echo -e "${YELLOW}Updating Aegis OS (${AEGIS_MODE})...${NC}"
    # Re-use the installer as it handles updates gracefully
    curl -sSL "https://raw.githubusercontent.com/Gustavo324234/Aegis-Core/main/installer/install.sh" | sudo bash
}

cmd_token() {
    echo -e "${CYAN}Retrieving Setup Token...${NC}"
    local token
    token=""
    if [[ "$AEGIS_MODE" == "docker" ]]; then
        token=$(cd "$INSTALL_DIR" && docker compose logs "$DOCKER_SERVICE" 2>&1 | grep -oP 'setup_token=\K[a-f0-9]{32}' | tail -n 1 || echo "")
    else
        token=$(journalctl -u "$SERVICE_NAME" -n 2000 --no-pager | grep -oP 'setup_token=\K[a-f0-9]{32}' | tail -n 1 || echo "")
    fi

    if [[ -z "$token" ]]; then
        echo -e "${YELLOW}No setup token found. If the system is initialized, token is disabled.${NC}"
    else
        echo -e "\n${GREEN}Setup URL: http://$(hostname -I | awk '{print $1}'):8000?setup_token=$token${NC}"
    fi
}

cmd_uninstall() {
    sudo bash -c "$(curl -sSL https://raw.githubusercontent.com/Gustavo324234/Aegis-Core/main/installer/uninstall.sh)" -- "$@"
}

# --- Execution ---

case "${1:-help}" in
    start)     shift; cmd_start "$@" ;;
    stop)      shift; cmd_stop "$@" ;;
    restart)   shift; cmd_stop "$@"; cmd_start "$@" ;;
    status)    shift; cmd_status "$@" ;;
    diag)      shift; cmd_diag "$@" ;;
    logs)      shift; cmd_logs "$@" ;;
    update)    shift; cmd_update "$@" ;;
    token)     shift; cmd_token "$@" ;;
    uninstall) shift; cmd_uninstall "$@" ;;
    help|*)
        echo "Aegis OS Unified CLI"
        echo ""
        echo "Usage: aegis {command} [args]"
        echo ""
        echo "Commands:"
        echo "  start       Start Aegis service"
        echo "  stop        Stop Aegis service"
        echo "  status      Check high-level status"
        echo "  diag        Run deep diagnostic report"
        echo "  logs [N]    Follow logs (default 100)"
        echo "  update      Update to latest version"
        echo "  token       Get setup URL"
        echo "  uninstall   Remove Aegis from system"
        exit 1
        ;;
esac
