AEGIS_ROOT_KEY=changeme_run_openssl_rand_hex_32
AEGIS_MTLS_STRICT=false

# TTS — EspeakEngine (requiere: apt install espeak-ng)
AEGIS_TTS_VOICE=es          # Idioma: "es" (español), "en" (inglés), "es-la" (latinoam.)
AEGIS_TTS_SPEED=150         # Palabras por minuto (100-300, default 150)

# Puerto HTTP del servidor Aegis (default: 8000)
# Cambiar si el puerto 8000 está ocupado por otro servicio en el host
ANK_HTTP_PORT=8000

